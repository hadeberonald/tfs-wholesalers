# --- Meta / WhatsApp Cloud API ---
# From App Dashboard > WhatsApp > API Setup
WHATSAPP_TOKEN=your_temporary_or_permanent_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id

# Any string you choose — must match what you enter in the Meta webhook config
VERIFY_TOKEN=choose_a_random_secret_string

# Graph API version (bump this periodically)
GRAPH_API_VERSION=v20.0

# --- Server ---
PORT=3000

# --- MongoDB (sessions, agent queue, message routing) ---
# Get this from MongoDB Atlas: Database → Connect → Drivers → Node.js
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/whatsapp-bot

# --- Human handoff (Option B: relay to agents' real WhatsApp numbers) ---
# wa_id format: digits only, no +, e.g. 27735720641
ORDERS_AGENT_NUMBER=27000000001
SUPPORT_AGENT_NUMBER=27000000002

ANALYTICS_API_KEY=XND54ilfMnCe5Nh2hkQKIFaGJcbxekL5
